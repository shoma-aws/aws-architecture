# AWSサービスを操作するためのライブラリを読み込む
import boto3

# S3を操作する準備
s3 = boto3.client('s3')

# Comprehendを操作する準備
comprehend = boto3.client('comprehend')


# Lambdaが実行されたときに最初に呼ばれる関数
def lambda_handler(event, context):

# S3イベントから「どのバケットか」を取得
bucket = event['Records'][0]['s3']['bucket']['name']

# S3イベントから「どのファイルか」を取得
key = event['Records'][0]['s3']['object']['key']

# S3からファイルを取得（メールの内容）
response = s3.get_object(Bucket=bucket, Key=key)

# ファイルの中身を読み込み、文字列に変換（UTF-8形式）
text = response['Body'].read().decode('utf-8')

# Comprehendにテキストを渡して感情分析を実行
result = comprehend.detect_sentiment(
        Text=text,          # 分析する文章
        LanguageCode='ja'   # 日本語として解析
 )

# 分析結果（POSITIVE / NEGATIVE など）を取得
sentiment = result['Sentiment']

# 結果をログに出力（CloudWatchで確認できる）
print(sentiment)
